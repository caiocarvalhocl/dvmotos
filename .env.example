# ============================================
# DV Motos - Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git!
# ============================================

# --- Database ---
POSTGRES_DB=dvmotos
POSTGRES_USER=dvmotos
POSTGRES_PASSWORD=CHANGE_ME_USE_A_STRONG_PASSWORD

# --- JWT ---
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# --- pgAdmin (dev only) ---
PGADMIN_EMAIL=admin@dvmotos.com.br
PGADMIN_PASSWORD=CHANGE_ME

# --- Initial Admin User (only used on first run) ---
ADMIN_EMAIL=admin@dvmotos.com.br
ADMIN_PASSWORD=CHANGE_ME_INITIAL_ADMIN_PASSWORD
